{
  "title": "Get Services Example",
  "description": "Example response for listing all service names registered in Zipkin",
  "request": {
    "method": "GET",
    "path": "/api/v2/services",
    "headers": {
      "Accept": "application/json"
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "body": [
      "frontend",
      "backend-api",
      "database-service",
      "cache-service",
      "auth-service"
    ]
  }
}
